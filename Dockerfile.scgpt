# scGPT Service Dockerfile
FROM python:3.10-slim

WORKDIR /app

# 安装系统依赖
RUN apt-get update && apt-get install -y \
    build-essential \
    && rm -rf /var/lib/apt/lists/*

# 复制依赖文件
COPY requirements-scgpt.txt .

# 安装 Python 依赖
RUN pip install --no-cache-dir -r requirements-scgpt.txt

# 复制项目文件
COPY . .

# 暴露端口
EXPOSE 8001

# 启动命令
CMD ["uvicorn", "src.scgpt_service.main:app", "--host", "0.0.0.0", "--port", "8001"]
