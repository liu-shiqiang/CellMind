############## .bashrc 集群初始化环境脚本##############

## 基础设置
unset LD_PRELOAD  # 取消LD_PRELOAD环境变量，防止初始化失败
[ -f /etc/bashrc ] && . /etc/bashrc
source /home/HPCBase/tools/module-5.2.0/init/profile.sh

## 默认加载的HPC模块
module use /home/HPCBase/modulefiles/
module purge
module load compilers/gcc/12.2.0
module load compilers/cuda/11.8.0
module add  libs/openblas/0.3.18_bs2.4.0
module load libs/cudnn/8.8.1_cuda11
module load libs/nccl/2.16.5-1_cuda11.8

## 设置基础环境变量 可执行文件寻找路径
export PATH=$HOME/.local/bin:$HOME/bin:$HOME/Software/ollama/bin:/usr/local/bin:/usr/bin:/bin:$PATH
export HF_ENDPOINT=https://hf-mirror.com
export PYTHONPATH=/home/share/huadjyin/home/zhangzilin/genomix-agent:$PYTHONPATH
export LD_PRELOAD=/home/share/huadjyin/home/zhangzilin/.conda/envs/scGPTbai/lib/python3.9/site-packages/igraph.libs/libgomp-d22c30c5.so.1.0.0
export NCBI_API_KEY="924cad059f260a8db813ce5474e51b594408"
## 进行Conda 环境初始化
__conda_setup="$('/home/HPCBase/tools/anaconda3/bin/conda' 'shell.bash' 'hook' 2> /dev/null)"
if [ $? -eq 0 ]; then
    eval "$__conda_setup"
else
    if [ -f "/home/HPCBase/tools/anaconda3/etc/profile.d/conda.sh" ]; then
        . "/home/HPCBase/tools/anaconda3/etc/profile.d/conda.sh"
    else
        export PATH="/home/HPCBase/tools/anaconda3/bin:$PATH"
    fi
fi
unset __conda_setup

## 设置全局环境变量